# ─────────────────────────────────────────────────────────────────────────────
# SquatchScout environment
# Copy this file to `.env.local`. The values below are the *local* Supabase
# defaults and work out of the box once you run `supabase start` — no cloud
# account, no real secrets. Swap them for your hosted project values in prod.
# ─────────────────────────────────────────────────────────────────────────────

# Public site URL (used for SEO metadata + auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform commission taken on each booking (0.15 = 15%)
NEXT_PUBLIC_PLATFORM_FEE_RATE=0.15

# Demo mode: hides footer links to pages that still carry placeholder content
# (blog, legal terms/privacy). Pages stay routable by URL — flip to false to
# restore the links.
NEXT_PUBLIC_DEMO_MODE=false

# ── Supabase (local stack) ───────────────────────────────────────────────────
# These are the well-known local dev keys printed by `supabase start`.
# They are NOT secret (they only work against your local Docker stack).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# Server-only. Never expose to the browser. (Local demo value.)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ── Integrations (stubbed until you add keys) ────────────────────────────────
# Leave blank to run in mock mode (Phase 4+ wires these up for real).
# Stripe + Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Google Maps (address autocomplete, distance, geocoding)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Transactional email (Resend)
RESEND_API_KEY=
EMAIL_FROM="SquatchScout <hello@squatchscout.local>"

# ── Google OAuth ─────────────────────────────────────────────────────────────
# The provider is enabled in supabase/config.toml and reads these two vars.
# Leave blank to run without Google sign-in (everything else still works).
# Local: create a Google Cloud OAuth client (type "Web application") with
#   authorized redirect URI  http://127.0.0.1:54321/auth/v1/callback
# paste the values here, then `supabase stop && supabase start`.
# Hosted: configure the same client ID/secret in the Supabase dashboard
# (Auth → Providers → Google) — see README "Google OAuth" for the full steps.
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
